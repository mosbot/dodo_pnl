# ── Обязательно на проде ──────────────────────────────────────────

# Async-подключение к PostgreSQL (asyncpg). Наша схема — pnl_service.*
DATABASE_URL=postgresql+asyncpg://pnl_user:password@127.0.0.1:5432/postgres

# Секрет для подписи cookie-сессий и шифрования чувствительных полей в БД
# (PlanFact-ключи). 64 hex-байта, генерируется один раз и НЕ меняется
# (иначе инвалидируются все сессии и не расшифруются сохранённые ключи).
#   python -c 'import secrets; print(secrets.token_hex(32))'
# При заданном DATABASE_URL пустой SECRET_KEY = отказ старта (fail-hard).
SECRET_KEY=

# ── Dodo IS API (для /board и ops-метрик) ─────────────────────────
# На проде access_token обычно берётся из public.dodois_credentials
# (refresh делает соседний сервис). Для локальной разработки можно
# положить токен сюда.
DODO_IS_ACCESS_TOKEN=
DODO_IS_BASE_URL=https://api.dodois.io/dodopizza/ru
DODO_IS_AUTH_URL=https://api.dodois.io/auth

# ── Опционально ───────────────────────────────────────────────────

# Имя схемы наших таблиц. Менять не надо.
DB_SCHEMA=pnl_service

# PlanFact: ключи хранятся в БД (planfact_keys) per-тенант. Эта
# переменная — только env-fallback для юзеров без привязанного ключа.
PLANFACT_API_KEY=
PLANFACT_BASE_URL=https://api.planfact.io/api/v1

# TTL in-memory кэша PlanFact-клиента (секунды).
CACHE_TTL=3600
