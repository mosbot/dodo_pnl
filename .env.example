# PlanFact API ключ — сгенерировать в app.planfact.io → Настройки → Безопасность
PLANFACT_API_KEY=your_api_key_here

# Базовый URL API (обычно менять не нужно)
PLANFACT_BASE_URL=https://api.planfact.io/api/v1

# Путь к SQLite (внутри контейнера — /app/data/pnl.db)
DATABASE_PATH=./data/pnl.db

# TTL кэша запросов к PlanFact (секунды)
CACHE_TTL=300

# Порт приложения
PORT=8000

# Basic Auth для защиты дашборда (пусто = без авторизации)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
